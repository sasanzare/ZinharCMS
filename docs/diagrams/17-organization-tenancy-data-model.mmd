    CITEXT email UK "0001 unique, case-insensitive user email"
    TEXT name "0001 NOT NULL"
    BOOLEAN is_active "0001 default TRUE"
    TIMESTAMPTZ created_at "0001 default now()"
    TIMESTAMPTZ updated_at "0001 default now()"
  }

