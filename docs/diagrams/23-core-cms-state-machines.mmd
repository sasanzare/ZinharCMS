state "Content Entry Lifecycle [IMPLEMENTED] AMB-067 AMB-068 AMB-070" as ContentEntryLifecycle {
  state "Draft\nstatus=draft" as EntryDraft
  state "Pending Review\nstatus=pending_review" as EntryPending
  state "Published\nstatus=published" as EntryPublished
  state "Archived\nstatus=archived" as EntryArchived
  state "Deleted\nrow removed" as EntryDeleted

  [*] --> EntryDraft : POST /api/entries/{type_slug}; role org owner/admin/editor/author; quota check, plugin before-save, sanitize, validate, version=1
  EntryDraft --> EntryDraft : PUT /api/entries/{type_slug}/{id}; role org owner/admin/editor/author; plugin before-save, sanitize, validate, version+1
  EntryPending --> EntryPending : PUT /api/entries/{type_slug}/{id}; role org owner/admin/editor/author; plugin before-save, sanitize, validate, version+1
  EntryPublished --> EntryPublished : PUT /api/entries/{type_slug}/{id}; role org owner/admin/editor/author; plugin before-save, sanitize, validate, version+1, content cache invalidation
  EntryArchived --> EntryArchived : PUT /api/entries/{type_slug}/{id}; role org owner/admin/editor/author; plugin before-save, sanitize, validate, version+1
  EntryDraft --> EntryPending : POST /api/entries/{type_slug}/{id}/submit-review; role org owner/admin/editor/author; workflow check, version+1
  EntryDraft --> EntryPublished : POST /api/entries/{type_slug}/{id}/publish; role org owner/admin/editor; bypass review, version+1, published_at now, cache invalidation, plugin after-publish, entry.publish webhook
  EntryPending --> EntryPublished : POST /api/entries/{type_slug}/{id}/publish; role org owner/admin/editor; version+1, published_at now, cache invalidation, plugin after-publish, entry.publish webhook
  EntryPending --> EntryDraft : POST /api/entries/{type_slug}/{id}/reject or /restore; role org owner/admin/editor; version+1, published_at null
  EntryPending --> EntryDraft : POST /api/entries/{type_slug}/{id}/unpublish; role org owner/admin/editor; version+1, published_at null, cache invalidation, entry.unpublish webhook
  EntryPublished --> EntryDraft : POST /api/entries/{type_slug}/{id}/unpublish; role org owner/admin/editor; version+1, published_at null, cache invalidation, entry.unpublish webhook
  EntryPublished --> EntryDraft : POST /api/entries/{type_slug}/{id}/reject or /restore; role org owner/admin/editor; version+1, published_at null, no content cache invalidation or webhook found
  EntryPublished --> EntryArchived : POST /api/entries/{type_slug}/{id}/archive; role org owner/admin/editor; version+1, published_at null, content cache invalidation
  EntryArchived --> EntryDraft : POST /api/entries/{type_slug}/{id}/restore or /reject; role org owner/admin/editor; version+1, published_at null
  EntryArchived --> EntryDraft : POST /api/entries/{type_slug}/{id}/unpublish; role org owner/admin/editor; version+1, published_at null, cache invalidation, entry.unpublish webhook
  EntryDraft --> EntryDeleted : DELETE /api/entries/{type_slug}/{id}; role org owner/admin/editor; row delete, audit after mutation
  EntryPending --> EntryDeleted : DELETE /api/entries/{type_slug}/{id}; role org owner/admin/editor; row delete, audit after mutation
  EntryPublished --> EntryDeleted : DELETE /api/entries/{type_slug}/{id}; role org owner/admin/editor; row delete, cache invalidation, audit after mutation
  EntryArchived --> EntryDeleted : DELETE /api/entries/{type_slug}/{id}; role org owner/admin/editor; row delete, audit after mutation
  EntryDeleted --> [*]

  note right of EntryDraft
    No persisted rejected, unpublished, or restored entry state exists.
    Those route names resolve to status=draft.
  end note
}

state "Page Lifecycle [IMPLEMENTED] AMB-067 AMB-068 AMB-069 AMB-070" as PageLifecycle {
