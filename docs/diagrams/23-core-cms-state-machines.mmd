  PagePublished --> PagePublished : PUT /api/pages/{id}; role org owner/admin/editor/author; page JSON validation, version snapshot, preview broadcast, page cache invalidation
  PageArchived --> PageArchived : PUT /api/pages/{id}; role org owner/admin/editor/author; page JSON validation, version snapshot, preview broadcast
  PageDraft --> PagePending : POST /api/pages/{id}/submit-review; role org owner/admin/editor/author; workflow check, status mutation, preview broadcast, no version snapshot
  PageDraft --> PagePublished : POST /api/pages/{id}/publish; role org owner/admin/editor; bypass review, published_at now, cache invalidation, page.publish webhook, preview broadcast
  PagePending --> PagePublished : POST /api/pages/{id}/publish; role org owner/admin/editor; published_at now, cache invalidation, page.publish webhook, preview broadcast
  PagePending --> PageDraft : POST /api/pages/{id}/reject or /restore; role org owner/admin/editor; published_at null, preview broadcast, no cache invalidation or webhook found
  PagePending --> PageDraft : POST /api/pages/{id}/unpublish; role org owner/admin/editor; published_at null, cache invalidation, page.unpublish webhook, preview broadcast
  PagePublished --> PageDraft : POST /api/pages/{id}/unpublish; role org owner/admin/editor; published_at null, cache invalidation, page.unpublish webhook, preview broadcast
  PagePublished --> PageDraft : POST /api/pages/{id}/reject or /restore; role org owner/admin/editor; published_at null, preview broadcast, no cache invalidation or webhook found
  PagePublished --> PageArchived : POST /api/pages/{id}/archive; role org owner/admin/editor; published_at null, page cache invalidation, preview broadcast
  PageArchived --> PageDraft : POST /api/pages/{id}/restore or /reject; role org owner/admin/editor; published_at null, preview broadcast
  PageArchived --> PageDraft : POST /api/pages/{id}/unpublish; role org owner/admin/editor; published_at null, cache invalidation, page.unpublish webhook, preview broadcast
  PageDraft --> PageDeleted : DELETE /api/pages/{id}?confirm=true; role org owner/admin/editor; page and version rows deleted, audit after mutation
  PagePending --> PageDeleted : DELETE /api/pages/{id}?confirm=true; role org owner/admin/editor; page and version rows deleted, audit after mutation
  PagePublished --> PageDeleted : DELETE /api/pages/{id}?confirm=true; role org owner/admin/editor; cache invalidation, page and version rows deleted, audit after mutation
  PageArchived --> PageDeleted : DELETE /api/pages/{id}?confirm=true; role org owner/admin/editor; page and version rows deleted, audit after mutation
  PageDeleted --> [*]

  note right of PageDraft
    Frontend autosave uses PUT /api/pages/{id} only for existing pages.
    New pages require manual save before autosave can run.
  end note
}

state "Page Version Lifecycle [IMPLEMENTED] AMB-045 AMB-069" as PageVersionLifecycle {
  state "Version Snapshot\ncomplete page_json" as PageVersionSnapshot
  state "Restored As Draft\npage status=draft" as PageVersionRestored
  state "Deleted With Page\nFK cascade" as PageVersionDeleted

  [*] --> PageVersionSnapshot : POST /api/pages or PUT /api/pages/{id}; role org owner/admin/editor/author; create complete snapshot, max(version)+1
  PageVersionSnapshot --> PageVersionSnapshot : existing page autosave/save; role org owner/admin/editor/author; create another complete snapshot
  PageVersionSnapshot --> PageVersionRestored : POST /api/pages/{id}/versions/{version}/restore; role org owner/admin/editor; version>0, validate saved page_json, update page_json, status draft, published_at null, preview broadcast
  PageVersionRestored --> PageVersionSnapshot : restore route side effect; role org owner/admin/editor; create new snapshot from restored JSON
  PageVersionSnapshot --> PageVersionDeleted : DELETE /api/pages/{id}?confirm=true; role org owner/admin/editor; page delete cascades versions
  PageVersionDeleted --> [*]

  note right of PageVersionSnapshot
    Page versions store complete snapshots, not deltas.
    Status-only page transitions do not create version snapshots.
    No restore-from column is persisted.
  end note
}

state "Comment Lifecycle [IMPLEMENTED] AMB-039" as CommentLifecycle {
  state "Open\nresolved_at is null" as CommentOpen
  state "Resolved\nresolved_at and resolved_by set" as CommentResolved
  state "Deleted\nrow removed" as CommentDeleted

  [*] --> CommentOpen : POST /api/comments; role org owner/admin/editor/author; validate entity_type entry/page, ensure entity exists, trim body
  CommentOpen --> CommentResolved : POST /api/comments/{id}/resolve; role org owner/admin/editor; set resolved_at and resolved_by
  CommentResolved --> CommentOpen : DELETE /api/comments/{id}/resolve; role org owner/admin/editor; clear resolved_at and resolved_by
  CommentOpen --> CommentDeleted : DELETE /api/comments/{id}; role org owner/admin/editor; row delete
  CommentResolved --> CommentDeleted : DELETE /api/comments/{id}; role org owner/admin/editor; row delete
  CommentDeleted --> [*]

  note right of CommentOpen
    Comment state is derived from nullable columns.
    There is no comments.status column.
  end note
}

state "Webhook Delivery Lifecycle [PARTIAL] AMB-011 AMB-041" as WebhookDeliveryLifecycle {
  state "Dispatch Attempt\ntransient tokio task or test request" as WebhookAttempt
  state "Delivered\nstatus=delivered" as WebhookDelivered
  state "Failed\nstatus=failed" as WebhookFailed

  [*] --> WebhookAttempt : entry/page publish or unpublish, or POST /api/webhooks/{id}/test; sign HMAC, HTTP POST with timeout
  WebhookAttempt --> WebhookDelivered : HTTP success status; insert webhook_deliveries row with delivered status
  WebhookAttempt --> WebhookFailed : HTTP non-success or request error; insert webhook_deliveries row with failed status and error/status metadata
  WebhookDelivered --> [*]
  WebhookFailed --> [*] : no durable retry scheduler or attempt counter found
}

state "Plugin Lifecycle [PARTIAL] AMB-006 AMB-070" as PluginLifecycle {
  state "Enabled\ncms_plugins.is_enabled=true" as PluginEnabled
  state "Disabled\ncms_plugins.is_enabled=false" as PluginDisabled

  [*] --> PluginEnabled : migration seed and sync_builtin_plugins; built-in seo-auto enabled by default
  PluginEnabled --> PluginDisabled : POST /api/plugins/{plugin_key}/disable or PUT is_enabled=false; role global super_admin/admin; update cms_plugins
  PluginDisabled --> PluginEnabled : POST /api/plugins/{plugin_key}/enable or PUT is_enabled=true; role global super_admin/admin; update cms_plugins
  PluginEnabled --> PluginEnabled : entry before-save hook; system during create/update; built-in plugin may mutate entry data before validation persistence
  PluginEnabled --> PluginEnabled : entry after-publish hook; system after publish mutation; failure can occur after status has changed

  note right of PluginEnabled
    Implemented runtime executes built-in plugin hooks only.
    No arbitrary external plugin execution lifecycle was found.
  end note
}

