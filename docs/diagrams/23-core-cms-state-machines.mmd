  state "Pending Review\nstatus=pending_review" as PagePending
  state "Published\nstatus=published" as PagePublished
  state "Archived\nstatus=archived" as PageArchived
  state "Deleted\nrow removed" as PageDeleted

  [*] --> PageDraft : POST /api/pages; role org owner/admin/editor/author; quota check, page JSON validation, version snapshot, preview broadcast
