subgraph ci_support["CI and operational support"]
    backend_ci["Backend CI [IMPLEMENTED]\nRust stable, fmt, clippy, tests with PostgreSQL and Redis service containers"]
    frontend_ci["Frontend CI [IMPLEMENTED]\nNode 22, npm install, lint, typecheck, tests, build"]
    runbook["Operations runbook [PARTIAL]\nManual deployment order, backup reminder, health/readiness checks, rollback guidance"]
    no_deploy_pipeline["Deployment automation [DOCUMENTED ONLY]\nNo GitHub Actions deployment job found"]
end

subgraph prod_compose["docker-compose.prod.yml services"]
    frontend_prod["frontend service [IMPLEMENTED]\nBuilds frontend/Dockerfile.prod; exposes host 5173 -> container 80"]
    backend_prod["backend service [IMPLEMENTED]\nBuilds backend/Dockerfile.prod; exposes host 8080 -> container 8080"]
    postgres_prod["postgres service [IMPLEMENTED]\npostgres:16-alpine; no host port published"]
    redis_prod["redis service [IMPLEMENTED]\nredis:7-alpine appendonly yes; no host port published"]
end

subgraph frontend_container["Frontend container internals"]
    nginx_static["Nginx static SPA serving [IMPLEMENTED]\nnginx:1.27-alpine; try_files to index.html; long cache for /assets"]
    vite_api_build_arg["VITE_API_URL build argument [IMPLEMENTED]\nBrowser JavaScript calls this backend URL directly"]
    no_api_proxy["API proxy in frontend Nginx [DECISION REQUIRED]\nnginx.conf serves files only and does not proxy /api"]
end

subgraph backend_container["Backend container internals"]
    backend_binary["/app/cms-backend [IMPLEMENTED]\nDebian slim runtime, non-root cms user"]
    startup_migrations["Startup migrations [IMPLEMENTED]\ndb::run_migrations executes before serving requests; AMB-030"]
    default_admin_seed["Default admin seed [IMPLEMENTED]\nSeeds only when users table is empty"]
    app_checks["Application checks [IMPLEMENTED]\nGET /health and GET /ready exist in Axum"]
    backend_compose_health["Backend Compose healthcheck [PARTIAL]\n/health and /ready exist but are not wired into docker-compose.prod.yml; AMB-029"]
end

subgraph prod_data["Persistent data and storage"]
    postgres_volume["postgres_data volume [IMPLEMENTED]\nMounted at /var/lib/postgresql/data"]
    redis_volume["redis_data volume [IMPLEMENTED]\nMounted at /data; Redis AOF enabled"]
    uploads_volume["uploads volume [IMPLEMENTED]\nMounted at /app/uploads"]
    cms_uploads["CMS uploads [IMPLEMENTED]\nMedia files and generated image variants on local filesystem; AMB-002"]
    marketplace_artifacts["Marketplace artifacts [IMPLEMENTED]\nPackage artifacts share uploads volume with logical object keys; AMB-002"]
end

subgraph health_dependencies["Health checks and startup dependencies"]
    postgres_health["PostgreSQL healthcheck [IMPLEMENTED]\npg_isready"]
    redis_health["Redis healthcheck [IMPLEMENTED]\nredis-cli ping"]
    backend_depends["Backend depends_on [IMPLEMENTED]\nWaits for postgres and redis service_healthy"]
    frontend_depends["Frontend depends_on [PARTIAL]\nDepends on backend start only, not backend health"]
end

subgraph env_categories["Production environment categories"]
    env_database["Database and cache env [IMPLEMENTED]\nDATABASE_URL, REDIS_URL"]
    env_auth["Auth and security env [IMPLEMENTED]\nJWT_SECRET, token expiry, CORS_ORIGIN"]
    env_storage["Upload env [IMPLEMENTED]\nUPLOAD_DIR=/app/uploads, MAX_UPLOAD_SIZE"]
    env_billing["Billing env [PARTIAL]\nStripe secret, webhook secret, price ids, success/cancel/portal URLs"]
    env_email["Email env [IMPLEMENTED]\nEMAIL_PROVIDER log/disabled/webhook, EMAIL_FROM, EMAIL_WEBHOOK_URL"]
    env_runtime["Runtime env [IMPLEMENTED]\nRUST_LOG and PORT=8080"]
end

subgraph external_connectivity["External connectivity"]
    browser["Browser [EXTERNAL]\nLoads frontend from host port 5173"]
    stripe["Stripe [EXTERNAL]\nCheckout, portal, and inbound billing webhooks"]
    email_webhook["Email webhook endpoint [EXTERNAL]\nUsed only when EMAIL_PROVIDER=webhook; AMB-010"]
    webhook_receivers["External webhook consumers [EXTERNAL]\nReceive signed CMS event POSTs; AMB-011"]
end

subgraph deployment_decisions["Deployment limitations and decisions"]
    tls_decision["TLS termination and public reverse proxy [DECISION REQUIRED]\nNo repo evidence for Traefik, cloud load balancer, or TLS-enabled reverse proxy; AMB-028"]
    preview_scaling["Live preview horizontal scaling [PARTIAL]\nPreview channels are in-memory per backend process; AMB-020"]
    filesystem_scaling["Multiple backend replicas with local uploads [DECISION REQUIRED]\nLocal uploads volume must be shared/backed up or replaced by object storage; AMB-002"]
    migration_coordination["Migration coordination for replicas [DECISION REQUIRED]\nBackend runs migrations at startup; no separate migration job or lock strategy documented; AMB-030"]
    db_backup_strategy["Database backup automation [DECISION REQUIRED]\nRunbook says take backup, but Compose/Docker/CI do not implement backups; AMB-031"]
    artifact_backup_strategy["Upload and artifact backup automation [DECISION REQUIRED]\nNo automated backup for uploads volume or Marketplace artifacts; AMB-031"]
    redis_backup_assumption["Redis persistence and backup [PARTIAL]\nAOF and redis_data volume exist; backup/restore process is not implemented; AMB-031"]
end

