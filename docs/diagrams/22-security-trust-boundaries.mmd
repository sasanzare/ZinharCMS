subgraph browser_zone["Browser Boundary"]
  browser_storage["Browser localStorage [IMPLEMENTED]<br/>access token, optional refresh fallback, user, organizations, active organization"]
  refresh_cookie["Refresh cookie [IMPLEMENTED]<br/>zinhar_refresh_token; HttpOnly; SameSite=Lax; Path=/api/auth; Secure when configured"]
  untrusted_inputs["Untrusted browser input [IMPLEMENTED]<br/>JSON forms, rich text, multipart files, ZIP packages, webhook URLs"]
  frontend_guards["Frontend guards and navigation hiding [PARTIAL]<br/>RequireAuth and role-visible controls are UX only"]
end

subgraph ingress_boundary["HTTP Ingress And Middleware Boundary"]
  cors["Credentialed CORS [IMPLEMENTED]<br/>configured origin, Authorization, Content-Type, X-Organization-Id"]
  request_id["Request ID and tracing [IMPLEMENTED]<br/>x-request-id propagation and trace layer"]
  timeout["Request timeout [IMPLEMENTED]<br/>Tower timeout returns 408"]
  headers["Security headers and CSP [IMPLEMENTED]<br/>CSP, nosniff, same-origin referrer, DENY frame options, permissions policy"]
  body_limit["Body-size boundary [IMPLEMENTED]<br/>tenant routes use DefaultBodyLimit<br/>media and Marketplace package sizes are checked again"]
end

subgraph auth_boundary["Authentication Boundary"]
  password_hash["Password hashing [IMPLEMENTED]<br/>Argon2 verify and hash"]
  login_limit["Login rate limiting [IMPLEMENTED]<br/>login_attempts table; IP-based failed-attempt window"]
  access_token["Access token verification [IMPLEMENTED]<br/>Bearer JWT checked by auth and tenant middleware"]
  refresh_rotation["Refresh-token rotation [IMPLEMENTED]<br/>server stores refresh token hashes<br/>old token revoked on refresh"]
end

subgraph validation_boundary["Validation Boundary"]
  schema_validation["Content schema and entry validation [IMPLEMENTED]<br/>field schemas, required fields, types, slug rules"]
  richtext_sanitize["Rich-text sanitization [IMPLEMENTED]<br/>dangerous blocks removed; unsupported tags and attributes stripped"]
  page_json_validation["Page JSON validation [IMPLEMENTED]<br/>layout object, depth, node count, component key allowlist, metadata types"]
  media_validation["Media upload validation [IMPLEMENTED]<br/>MIME allowlist, file-signature detection, declared/detected type match"]
  package_validation["Marketplace package validation [IMPLEMENTED]<br/>manifest schema, product type, permissions, size, checksum, object key"]
  zip_validation["ZIP path and security scan [IMPLEMENTED]<br/>relative UTF-8 paths only; no unsafe segments; forbidden secrets and executable artifacts flagged"]
  webhook_ssrf["Webhook URL SSRF validation [IMPLEMENTED]<br/>http/https only; no credentials; localhost/private/link-local hosts rejected"]
  stripe_signature["Stripe signature verification [IMPLEMENTED]<br/>HMAC SHA-256 with timestamp tolerance"]
end

subgraph authorization_boundary["Authorization And Tenant Boundary"]
  auth_middleware["Backend auth middleware [IMPLEMENTED]<br/>authoritative JWT boundary for auth-only routes"]
  tenant_middleware["Tenant middleware [IMPLEMENTED]<br/>X-Organization-Id, active membership, rate limit, API quota"]
  rbac_checks["RBAC checks [IMPLEMENTED]<br/>global role and organization-role service checks in handlers"]
  rls_policies["PostgreSQL RLS [IMPLEMENTED]<br/>forced policies on tenant-owned tables"]
  bypass_tx["Explicit RLS bypass [PARTIAL] AMB-005<br/>only service code using begin_bypass_transaction sets rls_bypass=true"]
end

subgraph persistence_boundary["Persistence Boundary"]
  postgres["PostgreSQL [IMPLEMENTED]<br/>users, tokens, tenant data, audit logs, Marketplace metadata"]
  redis["Redis [IMPLEMENTED]<br/>delivery cache and rate-limit counters<br/>cache fallback exists only for delivery cache"]
  local_uploads["Local CMS upload storage [IMPLEMENTED]<br/>media files and variants under upload_dir"]
  local_artifacts["Local Marketplace artifact storage [DECISION REQUIRED] AMB-002 AMB-015<br/>packages stored under upload_dir by object key<br/>cleanup after validation/persistence failure is not proven"]
  audit_logs["Audit logs [IMPLEMENTED]<br/>sensitive organization, billing, and Marketplace actions"]
end

subgraph external_boundary["External Network Boundary"]
  webhook_hmac["Outbound webhook signing [IMPLEMENTED]<br/>X-CMS-Signature HMAC over JSON payload"]
  webhook_receiver["External webhook consumer [EXTERNAL]<br/>receives signed events over HTTP"]
  stripe_api["Stripe API and webhooks [EXTERNAL]<br/>checkout, portal, inbound signed events"]
  email_integration["Email integration [PARTIAL]<br/>delivery records with log/disabled/webhook provider modes; no specific provider assumed"]
end

subgraph decision_risks["Decision-Required Trust Boundary Risks"]
  static_uploads["Static /uploads [DECISION REQUIRED] AMB-021<br/>ServeDir exposes upload_dir by path; DB RLS does not authorize file bytes"]
  local_replica_risk["Local filesystem scaling risk [DECISION REQUIRED] AMB-002<br/>multiple backend replicas need shared uploads/artifacts or object storage decision"]
  marketplace_runtime["Marketplace executable runtime [PLANNED] AMB-006<br/>packages are validated and reviewed, but executable plugin sandbox/runtime is not implemented"]
end

