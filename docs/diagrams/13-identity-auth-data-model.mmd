    TIMESTAMPTZ joined_at "0008 nullable"
    TIMESTAMPTZ created_at "0008 NOT NULL DEFAULT now()"
    TIMESTAMPTZ updated_at "0008 NOT NULL DEFAULT now()"
  }

  organization_invitations {
    UUID id PK "0008 default gen_random_uuid()"
