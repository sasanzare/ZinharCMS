    JSONB settings "0008 NOT NULL DEFAULT object; organizations_settings_object"
    TIMESTAMPTZ created_at "0008 NOT NULL DEFAULT now()"
    TIMESTAMPTZ updated_at "0008 NOT NULL DEFAULT now()"
  }

  organization_members {
    UUID organization_id PK, FK "0008 REFERENCES organizations(id) ON DELETE CASCADE"
    UUID user_id PK, FK "0008 REFERENCES users(id) ON DELETE CASCADE; idx_organization_members_user"
    organization_member_role role "0008 owner, admin, editor, author, viewer, billing_manager"
