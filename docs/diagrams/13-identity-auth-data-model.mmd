%% Access tokens are signed JWTs from backend/src/services/jwt.rs and are not database rows.
%% Refresh-token rotation is implemented in backend/src/routes/auth.rs by revoking the used refresh_tokens row and inserting a new row.
%% refresh_tokens has no token_family, replaced_by_token_id, or last_used_at column in the current schema.
