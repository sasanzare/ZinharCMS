  users {
    UUID id PK "0001 default gen_random_uuid()"
    CITEXT email UK "0001 NOT NULL UNIQUE; idx_users_email"
    TEXT password_hash "0001 NOT NULL; Argon2 hash"
    TEXT name "0001 NOT NULL"
    TEXT avatar_url "0001 nullable"
    BOOLEAN is_active "0001 NOT NULL DEFAULT TRUE"
    TIMESTAMPTZ created_at "0001 NOT NULL DEFAULT now()"
    TIMESTAMPTZ updated_at "0001 NOT NULL DEFAULT now()"
  }

  roles {
    UUID id PK "0001 default gen_random_uuid()"
    TEXT name UK "0001 NOT NULL UNIQUE; seeded super_admin, admin, editor, author, viewer"
    TEXT_ARRAY permissions "0001 NOT NULL DEFAULT empty array; metadata, not dynamic runtime engine"
    TIMESTAMPTZ created_at "0001 NOT NULL DEFAULT now()"
    TIMESTAMPTZ updated_at "0001 NOT NULL DEFAULT now()"
  }

  user_roles {
    UUID user_id PK, FK "0001 REFERENCES users(id) ON DELETE CASCADE"
    UUID role_id PK, FK "0001 REFERENCES roles(id) ON DELETE CASCADE; idx_user_roles_role_id"
    TIMESTAMPTZ assigned_at "0001 NOT NULL DEFAULT now()"
  }

  refresh_tokens {
    UUID id PK "0001 default gen_random_uuid()"
    UUID user_id FK "0001 NOT NULL REFERENCES users(id) ON DELETE CASCADE; idx_refresh_tokens_user_id"
    TEXT token_hash UK "0001 NOT NULL UNIQUE; SHA-256 hash of refresh token"
    TIMESTAMPTZ expires_at "0001 NOT NULL"
    TIMESTAMPTZ revoked_at "0001 nullable; set during refresh or logout"
    TIMESTAMPTZ created_at "0001 NOT NULL DEFAULT now()"
  }

  login_attempts {
    UUID id PK "0007 default gen_random_uuid()"
    CITEXT email "0007 NOT NULL; no FK to users"
    TEXT ip_address "0007 NOT NULL"
    BOOLEAN succeeded "0007 NOT NULL DEFAULT FALSE"
    TIMESTAMPTZ attempted_at "0007 NOT NULL DEFAULT now()"
  }

  organizations {
    UUID id PK "0008 default gen_random_uuid()"
    TEXT name "0008 NOT NULL; organizations_name_not_empty"
    TEXT slug UK "0008 NOT NULL UNIQUE; organizations_slug_format"
