    end

    subgraph creator_submission["Creator and listing preparation [IMPLEMENTED]"]
        creator_request["POST /api/marketplace/creator creator request [IMPLEMENTED]"]
        creator_validate["validate_creator_profile: slug, display name, bio, support email [IMPLEMENTED]"]
        creator_pending["Upsert marketplace_creators status pending [IMPLEMENTED]"]
        creator_verify["PATCH /creators/{creator_id}/verification by global admin [IMPLEMENTED]"]
        creator_approved{"Creator status approved? [IMPLEMENTED]"}
        listing_create["Create/update marketplace_listings draft metadata [IMPLEMENTED]"]
