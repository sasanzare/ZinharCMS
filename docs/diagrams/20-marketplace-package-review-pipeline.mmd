    frontend_ui --> api_router
    api_router --> creator_request
    creator_request --> creator_validate --> creator_pending --> creator_verify --> creator_approved
    creator_approved -- "yes" --> listing_create --> listing_submit --> listing_review_check --> upload_start
    creator_approved -- "no" --> no_artifact_error
    upload_start --> multipart_parse --> manifest_json_check
    manifest_json_check -- "no" --> no_artifact_error
    manifest_json_check -- "yes" --> product_type_check
    product_type_check -- "no" --> no_artifact_error
    product_type_check -- "yes" --> file_check
    file_check -- "no" --> no_artifact_error
    file_check -- "yes" --> version_extract --> checksum --> object_key --> persist_artifact
    persist_artifact --> load_plan --> evaluate
    evaluate --> archive_inspection --> path_validation --> manifest_validation --> permission_validation --> static_report
    evaluate --> security_scan
    evaluate --> compatibility_eval
    static_report --> report_result
    security_scan --> report_result
    compatibility_eval --> report_result
    report_result -- "failed/high/critical" --> report_persistence --> tx_start
    report_result -- "passed/warning and low/medium risk" --> report_persistence
    tx_start --> insert_version --> insert_submission --> update_listing_status --> tx_commit --> audit_submit
    tx_start -. "insert/commit error after artifact write" .-> artifact_orphan
    update_listing_status -- "blocked" --> blocked_review --> review_queue
    update_listing_status -- "submitted" --> queued_review --> review_queue
    review_queue --> decision --> approve_guard
    approve_guard -- "yes approve" --> approve_updates --> review_event --> audit_review --> catalog_filter
    approve_guard -- "no approve" --> reject_updates --> review_event
    decision -- "reject/request_changes" --> reject_updates
    review_event --> audit_review
    review_queue --> moderation_action --> action_kind
    action_kind -- "suspend_listing" --> suspend_listing --> moderation_event
    action_kind -- "unpublish_version" --> unpublish_version --> moderation_event
    action_kind -- "emergency_block" --> emergency_block --> moderation_event
    moderation_event --> audit_moderation --> no_restore
    catalog_filter --> catalog_ui --> install_runtime
    catalog_ui --> purchase_runtime

