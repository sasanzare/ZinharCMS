        listing_review_check["validate_listing_for_review: approved creator, metadata, screenshots, pricing [IMPLEMENTED]"]
    end

    subgraph upload_preflight["Version upload preflight [IMPLEMENTED]"]
        upload_start["POST /listings/{listing_id}/versions/upload multipart [IMPLEMENTED]"]
        multipart_parse["Read manifest and file fields [IMPLEMENTED]"]
        manifest_json_check{"Manifest exists and is JSON object? [IMPLEMENTED]"}
        product_type_check{"Manifest type matches listing product_type? [IMPLEMENTED]"}
        file_check{"File exists and size is 1..52428800 bytes? [IMPLEMENTED]"}
