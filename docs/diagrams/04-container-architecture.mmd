subgraph external_actors["Actors and external clients"]
    browser["Browser [EXTERNAL]\nRuns admin UI and requests public assets"]
    consumer_app["Consumer website or application [EXTERNAL]\nCalls public Delivery API when content is published"]
end

subgraph deployed_containers["Deployed containers"]
    frontend_container["frontend container [IMPLEMENTED]\nNginx-served React build in prod; Vite dev app locally"]
    backend_container["backend container [IMPLEMENTED]\nRust/Axum modular monolith on port 8080"]
    postgres_container["postgres container [IMPLEMENTED]\nPostgreSQL 16"]
    redis_container["redis container [IMPLEMENTED]\nRedis 7"]
end

subgraph frontend_runtime["Browser-side application"]
    react_admin["React 19 / Vite admin application [IMPLEMENTED]\nUses local access token, refresh cookie, and active organization id"]
end

subgraph backend_process["Logical modules inside the Rust/Axum backend process - not microservices"]
    public_system_endpoints["Public system endpoints [IMPLEMENTED]\n/, /health, /ready, /openapi.json"]
    public_auth_endpoints["Public auth endpoints [IMPLEMENTED]\n/api/auth/register, /login, /refresh"]
    public_stripe_webhook["Public Stripe billing webhook [IMPLEMENTED]\n/api/billing/stripe/webhook"]
    authenticated_management_api["Authenticated management API [IMPLEMENTED]\nAuth middleware only: /api/auth/me, /logout, plugins, global/org workspace APIs"]
    tenant_management_api["Tenant-aware management API [IMPLEMENTED]\nTenant middleware: content, pages, media, comments, webhooks, billing, organizations"]
    marketplace_catalog["Marketplace catalog boundary [IMPLEMENTED]\nTenant-aware /api/marketplace/catalog, not anonymous public catalog; AMB-003"]
    marketplace_submission["Marketplace creator submission APIs [IMPLEMENTED]\nCreator profile, listing, version upload, validation, review, moderation"]
    delivery_api["Public Delivery API [IMPLEMENTED]\n/api/v1/content, pages, settings, navigation, sitemap, robots"]
    live_preview["WebSocket live preview [PARTIAL]\n/api/preview/{page_id}; in-memory channel per page; AMB-020"]
    preview_memory["In-memory preview channels [PARTIAL]\nHashMap keyed by page id with broadcast senders in backend state"]
    static_uploads["Static /uploads serving [PARTIAL]\nServeDir exposes file bytes by path; metadata APIs remain tenant-protected; AMB-021"]
end

subgraph data_stores["Data stores"]
    postgres_db["PostgreSQL database [IMPLEMENTED]\nSQLx pool, migrations, constraints, RLS policies"]
    redis_store["Redis [PARTIAL]\nDelivery cache fallback only; rate limit and readiness depend on Redis; AMB-012"]
end

subgraph filesystem_storage["Filesystem storage"]
    cms_media_storage["Local CMS media storage [IMPLEMENTED]\nUPLOAD_DIR organization folders and image variants; AMB-002"]
    marketplace_package_storage["Local Marketplace package storage [IMPLEMENTED]\nPackage artifacts under UPLOAD_DIR with logical object keys; AMB-002"]
end

subgraph external_services["External services"]
    stripe_service["Stripe [PARTIAL]\nBilling checkout, portal, and inbound webhook lifecycle"]
    email_integration["Email integration [IMPLEMENTED]\nProvider modes: log, disabled, webhook; no named SMTP/SES provider; AMB-010"]
    webhook_consumers["External webhook consumers [IMPLEMENTED]\nReceive signed outbound event POSTs"]
end

subgraph planned_infrastructure["Planned or unverified infrastructure excluded from implemented runtime"]
    s3_storage["S3-compatible object storage [DOCUMENTED ONLY]\nNo runtime provider code found"]
    cdn_edge["CDN for uploads/packages [DOCUMENTED ONLY]\nNo CDN integration found"]
    api_gateway["Separate API gateway deployment [DOCUMENTED ONLY]\nAxum is the backend app, not a standalone gateway"]
    queue_worker["Durable queue or worker [DOCUMENTED ONLY]\nWebhook dispatch uses transient tokio tasks; AMB-011"]
    preview_broker["Durable preview broker or pub/sub [DOCUMENTED ONLY]\nLive preview channels are in process; AMB-020"]
end

