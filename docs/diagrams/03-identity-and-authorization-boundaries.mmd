    reviewer_privilege["Reviewer privilege [IMPLEMENTED] AMB-023<br/>global admin check, no dedicated reviewer role"]
    moderator_privilege["Moderator privilege [IMPLEMENTED] AMB-023<br/>global admin check, no dedicated moderator role"]
    org_installation["Organization-owned installation [IMPLEMENTED] AMB-007<br/>tenant-scoped list and lifecycle APIs over forced RLS"]
    install_permission_snapshot["Installation permission snapshot [IMPLEMENTED] AMB-027<br/>manifest permissions must exactly match owner/admin approval; changes require reapproval"]
  end

  subgraph frontend_controls["Frontend controls"]
    require_auth["RequireAuth [FRONTEND ONLY] AMB-026<br/>redirects without stored access token"]
    nav_visibility["Navigation visibility [FRONTEND ONLY] AMB-026<br/>AppShell renders all nav items for authenticated users"]
    frontend_button_gates["Button/section gating [FRONTEND ONLY] AMB-026<br/>billing, organization, beta, marketplace review UI checks"]
  end

  subgraph permission_boundaries["Permission boundaries by domain"]
    global_admin_boundary["Global administration [HANDLER/SERVICE]<br/>rbac::require_any; super_admin bypasses global role checks"]
    plugin_boundary["Plugin management [HANDLER]<br/>global admin through plugin manager checks"]
    organization_boundary["Organization management [HANDLER + MIDDLEWARE + SQL/RLS]<br/>owner/admin rules over tenant context"]
    invitation_boundary["Invitations [HANDLER + SQL]<br/>owner required for owner invites, admin for other roles"]
    domain_boundary["Domains [HANDLER + SQL/RLS]<br/>organization owner/admin through require_org_admin"]
    billing_boundary["Billing [HANDLER + MIDDLEWARE + SQL/RLS]<br/>owner, admin, billing_manager"]
    content_boundary["Content operations [HANDLER + MIDDLEWARE + SQL/RLS]<br/>org admin/editor/author by operation"]
    workflow_boundary["Workflow transitions [HANDLER + SERVICE]<br/>org admin/editor reviewer plus workflow service"]
    creator_verification_boundary["Creator verification [HANDLER]<br/>global admin"]
    listing_creation_boundary["Listing creation [HANDLER + SQL]<br/>authenticated creator profile ownership"]
    review_decision_boundary["Review decisions [HANDLER + SERVICE]<br/>global admin plus review validation service"]
    moderation_boundary["Moderation [HANDLER + SERVICE + SQL]<br/>global admin plus moderation service and table updates"]
    catalog_boundary["Catalog access [MIDDLEWARE] AMB-003<br/>authenticated tenant catalog, not anonymous"]
    installation_boundary["Marketplace installation [HANDLER + SERVICE + SQL/RLS] AMB-027<br/>owner/admin manage lifecycle; all mutations remain organization-scoped"]
    runtime_policy_boundary["Marketplace runtime policy [IMPLEMENTED]<br/>permission-bound allowlist, safe entry point, bounded payload"]
    kill_switch_boundary["Marketplace kill switch [IMPLEMENTED]<br/>global admin or organization owner/admin; runtime status blocking"]
    adapter_boundary["Phase 8 host-owned adapters [IMPLEMENTED]<br/>Component registry, Template Import, public Hook contracts; tenant RLS"]
    installation_runtime_boundary["Concrete package execution [PLANNED] AMB-006<br/>Phase 7/8 policy and host adapters exist; uploaded code and external execution remain deferred"]
    beta_boundary["Beta and GA operations [HANDLER] AMB-024<br/>org admin/editor for tenant triage, global admin for product dashboard"]
  end

