  end

  subgraph marketplace_identity["Marketplace identity"]
    marketplace_user["User [IMPLEMENTED]<br/>same global user account"]
    creator_profile["Creator profile [IMPLEMENTED]<br/>status: pending, approved, suspended, rejected"]
