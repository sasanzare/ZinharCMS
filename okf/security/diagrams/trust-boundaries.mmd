  handler["Handler / service boundary\nRBAC, ownership, lifecycle, validation"]
  rls["PostgreSQL boundary\nTenant context and forced RLS"]
  bypass["Explicit RLS bypass\nPrivileged caller responsibility"]
  redis["Redis\nRate limit and cache"]
  files["Filesystem\nUploads and packages"]
  providers["External providers\nStripe, email, webhooks"]

