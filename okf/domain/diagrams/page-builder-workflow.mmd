%% title: ZinharCMS Page Builder Save, Version, and Restore Workflow
%% sources: frontend/src/pages/PagesPage.tsx; backend/src/routes/pages.rs; backend/migrations/0001_initial_schema.sql
flowchart TD
    Load["Load pages, component registries,<br/>Marketplace adapters and installations"] --> Edit["Edit local page draft"]
    Edit --> Validate["Backend validates title, slug,<br/>root, registered types, depth and count"]
    Validate -->|"Invalid"| Error["Return validation error<br/>retain dirty draft"]
    Validate -->|"Valid"| Tx["Tenant transaction"]
    Tx --> Page["Insert or update pages row"]
    Page --> Snapshot["Insert page_versions snapshot<br/>MAX(version) + 1"]
    Snapshot --> Commit["Commit"]
    Commit --> Broadcast["Broadcast page_json to preview subscribers"]
    Commit --> Cache["Invalidate public cache if published edit"]
    Commit --> Reload["Frontend replaces draft and reloads"]
    Versions["Select existing snapshot"] --> Revalidate["Validate against current registry"]
    Revalidate --> RestoreTx["Transaction: replace page_json,<br/>reset draft, append new snapshot"]
    RestoreTx --> Broadcast
    RestoreTx -.->|"cache invalidation not found"| CacheGap["Potential stale published cache"]

