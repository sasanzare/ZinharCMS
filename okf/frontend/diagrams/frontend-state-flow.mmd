    Page["Route page local state<br/>server data, forms, loading, errors"]
    Builder["Page Builder local draft<br/>dirty and autosave state"]
    API["Central API request"]
    Backend["Backend state"]

    Storage --> Store
    Storage --> ApiState
    Storage --> I18n
    User --> Store
    User --> I18n
    User --> Page
    User --> Builder
    Store --> Storage
    Store --> ApiState
    Store --> Shell
    I18n --> Shell
    I18n --> Page
    Store --> Page
    Page --> API
    Builder --> API
    ApiState --> API
    API --> Backend
