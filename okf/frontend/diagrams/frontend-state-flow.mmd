flowchart LR
    User["User interaction"]
    Storage["localStorage<br/>tokens, user, organizations, active organization, locale"]
    Store["Zustand useAppStore<br/>session, organization, sidebar"]
    ApiState["API module variables<br/>access token and organization"]
    I18n["I18n React context<br/>locale and direction"]
